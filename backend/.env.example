### ──────────────────────────────────────────────────────────────
# 1. Core LLM endpoints & keys (Server-Side)
### ──────────────────────────────────────────────────────────────

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://gemini.googleapis.com/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Claude (Anthropic)
ANTHROPIC_API_KEY=
CLAUDE_API_BASE_URL=https://api.anthropic.com/v1

# Perplexity (DeepResearch)
PERPLEXITY_API_KEY=
PERPLEXITY_API_BASE_URL=https://api.perplexity.ai/v1

# QWen (AI21 / Inspirit)
QWEN_API_KEY=
QWEN_API_BASE_URL=https://api.ai21.com/studio/v1/qwen

# DeepSeek (open-source)
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.ai/v1

### ──────────────────────────────────────────────────────────────
# 2. Application Settings
### ──────────────────────────────────────────────────────────────

# App URLs (Client-accessible)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend URL (Server-side)
BACKEND_URL=http://localhost:8000

# Database Configuration (Server-side)
DATABASE_URL=postgresql://user:password@localhost:5432/handywriterz
REDIS_URL=redis://localhost:6379

# Development & Testing
NODE_ENV=development
LOG_LEVEL=info
ENABLE_DEBUG_LOGGING=true

### ──────────────────────────────────────────────────────────────
# 3. Dynamic.xyz Wallet & Payments
### ──────────────────────────────────────────────────────────────

# This ID is exposed to the client-side SDK for Dynamic.xyz
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# These are server-side secrets for Dynamic.xyz
DYNAMIC_PUBLIC_KEY=
DYNAMIC_PRIVATE_KEY=
DYNAMIC_WEBHOOK_SECRET=

### ──────────────────────────────────────────────────────────────
# 4. Feature Flags (Client-Side)
### ──────────────────────────────────────────────────────────────

# These flags are exposed to the client and start with NEXT_PUBLIC_
NEXT_PUBLIC_ENABLE_DOCX_CONVERT=true
NEXT_PUBLIC_ENABLE_UNMUTE=true
NEXT_PUBLIC_ENABLE_MM_RESEARCH=true
NEXT_PUBLIC_ENABLE_TUTOR_REVIEW=true
NEXT_PUBLIC_ENABLE_SUBSCRIPTION_BILLING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

### ──────────────────────────────────────────────────────────────
# 5. Pricing Configuration (Client-Side)
### ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_PRICE_PER_PAGE_GBP=12
NEXT_PUBLIC_WORDS_PER_PAGE=275
NEXT_PUBLIC_SUBSCRIPTION_MONTHLY_GBP=20
NEXT_PUBLIC_TRIAL_WORD_LIMIT=1000

### ──────────────────────────────────────────────────────────────
# 6. External Services
### ──────────────────────────────────────────────────────────────

# Turnitin Checker Hub (Client-Side URL)
NEXT_PUBLIC_CHECKER_BASE_URL=https://checker.handywriterz.com

# Turnitin API (Server-Side)
TURNITIN_API_KEY=
TURNITIN_WEBHOOK_URL=
TURNITIN_TELEGRAM_BOT_TOKEN=
TURNITIN_TELEGRAM_CHAT_ID=

# File Storage (Cloudflare R2 - Server-Side)
R2_BUCKET_NAME=handywriterz-documents
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Email Service (Server-Side)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@handywriterz.com

### ──────────────────────────────────────────────────────────────
# 7. Security & CORS (Server-Side)
### ──────────────────────────────────────────────────────────────

# For Next.js, CORS is typically handled in next.config.js, but placing here for reference
CORS_ALLOW_ORIGIN=http://localhost:3000;https://app.handywriterz.com
FORWARDED_ALLOW_IPS=app.handywriterz.com

# Security Keys
JWT_SECRET=
ENCRYPTION_KEY=
SESSION_SECRET=
USE_SECURE_COOKIES=true

### ──────────────────────────────────────────────────────────────
# 8. Analytics & Monitoring
### ──────────────────────────────────────────────────────────────

# Telemetry (Server-Side)
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

# Optional Monitoring Services (Server-Side)
HONEYCOMB_API_KEY=
SENTRY_DSN=
POSTHOG_KEY=

### ──────────────────────────────────────────────────────────────
# 9. Rate Limiting (Server-Side)
### ──────────────────────────────────────────────────────────────

RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
RATE_LIMIT=1000   # per hour, per IP

