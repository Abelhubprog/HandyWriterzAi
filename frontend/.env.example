NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp0YmtncnBjaGRuempmcXhpcm54Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTMxMDg4MTQsImV4cCI6MjA2ODY4NDgxNH0.zLCTMc29i4PPPZtnb0BjT-Yl3L3Pr3Swqie2QPtVqmw

### ──────────────────────────────────────────────────────────────
# 3. Dynamic.xyz Wallet Configuration (Client-Side)
### ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_DYNAMIC_ENV_ID=your_dynamic_env_id_here

### ──────────────────────────────────────────────────────────────
# 4. Feature Flags (Client-Side)
### ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_DOCX_CONVERT=true
NEXT_PUBLIC_ENABLE_MULTIMODAL_UPLOAD=true
NEXT_PUBLIC_ENABLE_REAL_TIME_COLLABORATION=true
NEXT_PUBLIC_ENABLE_VOICE_INPUT=true
NEXT_PUBLIC_ENABLE_VIDEO_PROCESSING=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_DEMO_MODE=true

### ──────────────────────────────────────────────────────────────
# 5. YC Demo Day Configuration (Client-Side)
### ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_USER_EMAIL=demo@handywriterz.com
NEXT_PUBLIC_TARGET_PROCESSING_TIME=807
NEXT_PUBLIC_TARGET_QUALITY_SCORE=9.1
NEXT_PUBLIC_TARGET_ORIGINALITY_PERCENTAGE=88.7

### ──────────────────────────────────────────────────────────────
# 6. Application Settings
### ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=HandyWriterz
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_ENVIRONMENT=production
